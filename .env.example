# Copy to .env (do NOT commit .env)
#
# This file lists environment variables used by the capstone.
# Keep values empty or placeholder-safe.

############################
# Phase 2 — Play Store reviews fetch
############################

# Google Play app id (default used by code is in.indwealth)
APP_ID=in.indwealth

# Weeks back to fetch (clamped to 8–12 by the fetcher)
WEEKS_BACK=10

# Max reviews to keep after filtering
MAX_REVIEWS=500

############################
# Phase 4 — Booking agent
############################

# Booking code prefix (default: IN)
BOOKING_PREFIX=IN

############################
# Optional — LLM integration (not required yet)
############################

# If you later enable Groq-based generation
GROQ_API_KEY=

############################
# Optional — Voice stack (from your voiceagent repo) (not wired yet)
############################

GEMINI_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
USE_GEMINI_PULSE=0

